            <!-- Project 3 Config -->
            <property name="project3Type" type="String" label="Project 3 Category Badge" default="Category" />
            <property name="project3Title" type="String" label="Project 3 Title" default="Project 3 Title" />
            <property name="project3Desc" type="String" label="Project 3 Description" default="A description of your third project explaining what it does, who it was for, and the core benefits." />
